      "n_steward_suite": {
        "id": "n_steward_suite",
        "type": "narrative",
        "text": "Brigetta's ghost appears in the mirror and asks if you truly mean to save Ireena.",
        "choices": [
          {
            "id": "c_assure_brigetta",
            "label": "\"I give you my word: we'll protect her.\"",
            "mechanic": {
              "type": "skill_check",
              "dice": "1d20",
              "dc": 12,
              "attribute": "intelligence",
              "skillId": "persuasion",
              "onSuccess": { "nextNodeId": "n_brigetta_trust" },
              "onFailure": { "nextNodeId": "n_brigetta_cold" }
