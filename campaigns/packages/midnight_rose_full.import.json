          {
            "id": "c_find_secret",
            "label": "[Investigation DC 13]",
            "mechanic": {
              "type": "skill_check",
              "dice": "1d20",
              "dc": 13,
              "attribute": "intelligence",
              "skillId": "investigation",
              "onSuccess": { "nextNodeId": "n_secret_room" },
              "onFailure": { "nextNodeId": "n_law_fail" }
