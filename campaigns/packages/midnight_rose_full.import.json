          { "action": "set_flag", "key": "time_7pm", "value": true }
        ],
        "choices": [
          { "id": "c_law_office", "label": "[Law office]", "mechanic": { "type": "navigate", "nextNodeId": "n_law_office" } },
          { "id": "c_steward_suite", "label": "[Steward suite]", "mechanic": { "type": "navigate", "nextNodeId": "n_steward_suite" } },
          { "id": "c_attic_entry", "label": "[Attic stairs]", "mechanic": { "type": "navigate", "nextNodeId": "n_attic_entry" } }
        ]
      },
      "n_law_office": {
        "id": "n_law_office",
        "type": "narrative",
        "text": "A hidden compartment in a law shelf can be found by logic or luck.",
