        "text": "She steadies. \"Then let's survive this.\"",
        "onEnter": [
          { "action": "set_flag", "key": "ireena_trusts_party", "value": true }
        ],
        "choices": [
          { "id": "c_to_boss_after_trust", "label": "[Fight the Dursts]", "mechanic": { "type": "navigate", "nextNodeId": "n_dark_heart_threshold" } }
        ]
      },
      "n_ireena_fear": {
        "id": "n_ireena_fear",
        "type": "narrative",
        "text": "She panics and pulls free, making the opening attack harder.",
        "onEnter": [
          { "action": "adjust_hp", "amount": -2 }
        ],
        "choices": [
          { "id": "c_to_boss_after_fear", "label": "[Fight anyway]", "mechanic": { "type": "navigate", "nextNodeId": "n_dark_heart_threshold" } }
        ]
      },
      "n_dark_heart_victory": {
        "id": "n_dark_heart_victory",
        "type": "narrative",
        "text": "The Dursts fall. The house convulses and starts collapsing. You must escape now.",
        "onEnter": [
          { "action": "set_flag", "key": "rescued_ireena", "value": true },
          { "action": "set_flag", "key": "escape_started", "value": true }
        ],
        "choices": [
          { "id": "c_escape_start", "label": "[Run for the stairs]", "mechanic": { "type": "navigate", "nextNodeId": "n_escape_upper_hall" } }
        ]
      },
      "n_escape_upper_hall": {
        "id": "n_escape_upper_hall",
        "type": "encounter",
        "text": "Animated armor blocks the upper hall as fire spreads.",
        "choices": [
          { "id": "c_fight_escape_armor", "label": "[Break through]", "mechanic": { "type": "combat_init", "encounterId": "enc_escape_armor" } },
          { "id": "c_use_trapdoor", "label": "[Use hidden trapdoor route]", "visibilityRequirements": [{ "type": "has_flag", "key": "trapdoor_open" }], "mechanic": { "type": "navigate", "nextNodeId": "n_escape_foyer" } }
        ]
      },
      "n_escape_armor_clear": {
        "id": "n_escape_armor_clear",
        "type": "narrative",
        "text": "The armor collapses and the path opens.",
        "choices": [
          { "id": "c_to_escape_foyer", "label": "[Run for foyer]", "mechanic": { "type": "navigate", "nextNodeId": "n_escape_foyer" } }
        ]
      },
      "n_escape_foyer": {
        "id": "n_escape_foyer",
        "type": "encounter",
        "text": "A living rug tries to drag you back into burning corridors.",
        "choices": [
          { "id": "c_fight_rug", "label": "[Cut through]", "mechanic": { "type": "combat_init", "encounterId": "enc_escape_rug" } },
          { "id": "c_dash_gate", "label": "[Dash for the gate]", "mechanic": { "type": "navigate", "nextNodeId": "n_escape_gate" } }
        ]
      },
      "n_escape_rug_clear": {
        "id": "n_escape_rug_clear",
        "type": "narrative",
        "text": "The rug unravels. The front gate twists into a jaw of teeth.",
        "choices": [
          { "id": "c_to_escape_gate_2", "label": "[Face the gate]", "mechanic": { "type": "navigate", "nextNodeId": "n_escape_gate" } }
        ]
      },
      "n_escape_gate": {
        "id": "n_escape_gate",
        "type": "narrative",
        "text": "You need perfect timing to pass the snapping doorway.",
        "choices": [
          { "id": "c_escape_acrobatics", "label": "[Acrobatics DC 13]", "mechanic": { "type": "skill_check", "dice": "1d20", "dc": 13, "attribute": "dexterity", "skillId": "acrobatics", "onSuccess": { "nextNodeId": "n_survivors" }, "onFailure": { "nextNodeId": "n_escape_wounded" } } },
          { "id": "c_escape_read_pattern", "label": "[Perception DC 13]", "mechanic": { "type": "skill_check", "dice": "1d20", "dc": 13, "attribute": "intelligence", "skillId": "perception", "onSuccess": { "nextNodeId": "n_survivors" }, "onFailure": { "nextNodeId": "n_escape_wounded" } } },
          { "id": "c_escape_reckless", "label": "[Force through]", "mechanic": { "type": "navigate", "nextNodeId": "n_escape_wounded" } }
        ]
      },
      "n_escape_wounded": {
        "id": "n_escape_wounded",
        "type": "narrative",
        "text": "The teeth rake your side as you force your way through.",
        "onEnter": [
          { "action": "adjust_hp", "amount": -10 }
        ],
        "choices": [
          { "id": "c_survive_gt0", "label": "[Keep moving with Ireena]", "visibilityRequirements": [{ "type": "stat_check", "stat": "hpCurrent", "operator": ">", "value": 0 }], "mechanic": { "type": "navigate", "nextNodeId": "n_survivors" } },
          { "id": "c_doomed_lte0", "label": "[Collapse in the doorway]", "visibilityRequirements": [{ "type": "stat_check", "stat": "hpCurrent", "operator": "<=", "value": 0 }], "mechanic": { "type": "navigate", "nextNodeId": "n_doomed" } }
        ]
      },
      "n_survivors": {
        "id": "n_survivors",
        "type": "ending",
        "text": "You escape with Ireena before midnight as Death House collapses into the fog.",
        "onEnter": [
          { "action": "adjust_currency", "amount": 100 }
        ],
        "choices": [
          { "id": "c_survivor_talk", "label": "\"Tell me where these mists lead.\"", "mechanic": { "type": "navigate", "nextNodeId": "n_camp_dialogue" } },
          { "id": "c_restart_survivors", "label": "[Play again]", "mechanic": { "type": "navigate", "nextNodeId": "n_start" } }
        ]
      },
      "n_camp_dialogue": {
        "id": "n_camp_dialogue",
        "type": "ending",
        "text": "Kolyan and Ismark thank you at a hunting camp. Dawn will bring a harder road.",
        "choices": [
          { "id": "c_camp_lore", "label": "\"What exactly is Barovia?\"", "mechanic": { "type": "navigate", "nextNodeId": "n_camp_lore" } },
          { "id": "c_camp_restart", "label": "[End run]", "mechanic": { "type": "navigate", "nextNodeId": "n_start" } }
        ]
      },
      "n_camp_lore": {
        "id": "n_camp_lore",
        "type": "ending",
        "text": "They warn you this was only the first test the Mists had planned.",
        "choices": [
          { "id": "c_back_camp", "label": "[Back]", "mechanic": { "type": "navigate", "nextNodeId": "n_camp_dialogue" } }
        ]
      },
      "n_doomed": {
        "id": "n_doomed",
        "type": "ending",
        "text": "Midnight claims the doomed. Death House keeps your name.",
        "choices": [
          { "id": "c_restart_doomed", "label": "[Try again]", "mechanic": { "type": "navigate", "nextNodeId": "n_start" } }
        ]
      },
      "n_game_over": {
        "id": "n_game_over",
        "type": "ending",
        "text": "Your story ends in the dark below Death House.",
        "choices": [
          { "id": "c_restart_game_over", "label": "[Try again]", "mechanic": { "type": "navigate", "nextNodeId": "n_start" } }
        ]
      }
