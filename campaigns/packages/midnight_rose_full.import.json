          { "id": "c_back_upper_4", "label": "[Back]", "mechanic": { "type": "navigate", "nextNodeId": "n_upper_hall" } }
        ]
      },
      "n_brigetta_trust": {
        "id": "n_brigetta_trust",
        "type": "narrative",
        "text": "Brigetta points to hidden attic rafters and warns of a spider nest.",
        "onEnter": [
          { "action": "set_flag", "key": "brigetta_trust", "value": true }
        ],
        "choices": [
          { "id": "c_to_attic_from_brigetta", "label": "[Go to attic]", "mechanic": { "type": "navigate", "nextNodeId": "n_attic_entry" } }
