{
  "manifest": {
    "storyId": "balor_party_v4_mechanics",
    "title": "The Hangover: A Real Balor Party (Mechanics Complete)",
    "author": "Greg Bilsland (Adapted + Systems Rewrite)",
    "version": "4.0.0",
    "description": "Trial story rewritten to exercise all supported mechanics: actions, visibility logic, skill proficiency checks, combat branches, consumables, and armor-driven loot."
  },
  "model": {
    "nodes": {
      "n_start": {
        "id": "n_start",
        "type": "narrative",
        "text": "Morning light, shattered furniture, one white chicken, one drow baby, and one catastrophic hangover. Whoever you are, your sheet was chosen before this mess began.",
        "onEnter": [
          { "action": "set_flag", "key": "run_started", "value": true },
          { "action": "adjust_currency", "amount": 20 }
        ],
        "choices": [
          { "id": "c_to_suite_hub", "label": "[Take stock of the suite]", "mechanic": { "type": "navigate", "nextNodeId": "n_suite_hub" } }
        ]
      },
      "n_suite_hub": {
        "id": "n_suite_hub",
        "type": "narrative",
        "text": "The suite is ruined: blood on the minibar, claw marks near the bathroom, and a locked dresser with scorch marks.",
        "choices": [
          { "id": "c_pockets", "label": "[Search your pockets]", "visibilityRequirements": [{ "type": "not_has_flag", "key": "searched_pockets" }], "mechanic": { "type": "navigate", "nextNodeId": "n_search_pockets" } },
          { "id": "c_dresser", "label": "[Inspect locked dresser]", "visibilityRequirements": [{ "type": "not_has_flag", "key": "opened_dresser" }], "mechanic": { "type": "navigate", "nextNodeId": "n_dresser" } },
          { "id": "c_bathroom", "label": "[Open bathroom door]", "mechanic": { "type": "navigate", "nextNodeId": "n_bathroom_door" } }
        ]
      },
      "n_search_pockets": {
        "id": "n_search_pockets",
        "type": "narrative",
        "text": "You find a receipt marked OBLIVION and a brass token for Mik Tystone's private estate.",
        "onEnter": [
          { "action": "set_flag", "key": "searched_pockets", "value": true },
          { "action": "add_item", "itemId": "receipt_oblivion", "qty": 1 },
          { "action": "add_item", "itemId": "club_token", "qty": 1 }
        ],
        "choices": [
          { "id": "c_back_suite_1", "label": "[Back]", "mechanic": { "type": "navigate", "nextNodeId": "n_suite_hub" } }
        ]
      },
      "n_dresser": {
        "id": "n_dresser",
        "type": "narrative",
        "text": "The lock is delicate but old. You can finesse it, force it, or study the hidden seams.",
        "choices": [
          {
            "id": "c_pick_lock",
            "label": "[Pick lock (Sleight of Hand DC 13)]",
            "mechanic": {
              "type": "skill_check",
              "dice": "1d20",
              "dc": 13,
              "attribute": "dexterity",
              "skillId": "sleight_of_hand",
              "onSuccess": { "nextNodeId": "n_dresser_success" },
              "onFailure": { "nextNodeId": "n_dresser_fail" }
            }
          },
          {
            "id": "c_force_dresser",
            "label": "[Force with leverage (Athletics DC 12)]",
            "mechanic": {
              "type": "skill_check",
              "dice": "1d20",
              "dc": 12,
              "attribute": "strength",
              "skillId": "athletics",
              "onSuccess": { "nextNodeId": "n_dresser_success" },
              "onFailure": { "nextNodeId": "n_dresser_fail" }
            }
          },
          {
            "id": "c_study_mechanism",
            "label": "[Study mechanism (Investigation DC 12)]",
            "mechanic": {
              "type": "skill_check",
              "dice": "1d20",
              "dc": 12,
              "attribute": "intelligence",
              "skillId": "investigation",
              "onSuccess": { "nextNodeId": "n_dresser_success" },
              "onFailure": { "nextNodeId": "n_dresser_fail" }
            }
          }
        ]
      },
      "n_dresser_success": {
        "id": "n_dresser_success",
        "type": "narrative",
        "text": "Inside: a reinforced jacket, a potion, and a note saying: \"Mik took the baby before dawn.\"",
        "onEnter": [
          { "action": "set_flag", "key": "opened_dresser", "value": true },
          { "action": "set_flag", "key": "learned_mik_has_baby", "value": true },
          { "action": "add_item", "itemId": "gambler_jacket", "qty": 1 },
          { "action": "add_item", "itemId": "health_potion", "qty": 1 }
        ],
        "choices": [
          { "id": "c_back_suite_2", "label": "[Back]", "mechanic": { "type": "navigate", "nextNodeId": "n_suite_hub" } }
        ]
      },
      "n_dresser_fail": {
        "id": "n_dresser_fail",
        "type": "narrative",
        "text": "You spring a tiny trap needle and feel your pulse spike.",
        "onEnter": [
          { "action": "set_flag", "key": "opened_dresser", "value": true },
          { "action": "adjust_hp", "amount": -3 }
        ],
        "choices": [
          { "id": "c_back_suite_3", "label": "[Back]", "mechanic": { "type": "navigate", "nextNodeId": "n_suite_hub" } }
        ]
      },
      "n_bathroom_door": {
        "id": "n_bathroom_door",
        "type": "encounter",
        "text": "A makeup-smeared owlbear stands in the bathtub and huffs angrily.",
        "choices": [
          {
            "id": "c_read_owlbear",
            "label": "[Read its mood (Insight DC 11)]",
            "mechanic": {
              "type": "skill_check",
              "dice": "1d20",
              "dc": 11,
              "attribute": "intelligence",
              "skillId": "insight",
              "onSuccess": { "nextNodeId": "n_owlbear_handle" },
              "onFailure": { "nextNodeId": "n_owlbear_handle" }
            }
          },
          { "id": "c_attack_owlbear", "label": "[Attack first]", "mechanic": { "type": "combat_init", "encounterId": "enc_owlbear_suite" } }
        ]
      },
      "n_owlbear_handle": {
        "id": "n_owlbear_handle",
        "type": "narrative",
        "text": "You can try to calm it with confident posture and tone, or escalate.",
        "choices": [
          {
            "id": "c_calm_owlbear",
            "label": "[Animal Handling DC 14]",
            "mechanic": {
              "type": "skill_check",
              "dice": "1d20",
              "dc": 14,
              "attribute": "intelligence",
              "skillId": "animal_handling",
              "onSuccess": { "nextNodeId": "n_owlbear_calm" },
              "onFailure": { "nextNodeId": "n_owlbear_angered" },
              "onFailureEncounterId": "enc_owlbear_suite"
            }
          },
          { "id": "c_force_fight_owlbear", "label": "[Fight now]", "mechanic": { "type": "combat_init", "encounterId": "enc_owlbear_suite" } }
        ]
      },
      "n_owlbear_angered": {
        "id": "n_owlbear_angered",
        "type": "narrative",
        "text": "The owlbear screeches and lunges.",
        "choices": [
          { "id": "c_defend_owlbear", "label": "[Defend yourself]", "mechanic": { "type": "combat_init", "encounterId": "enc_owlbear_suite" } }
        ]
      },
      "n_owlbear_calm": {
        "id": "n_owlbear_calm",
        "type": "narrative",
        "text": "It settles and lets you read its collar: \"MacGuffin - property of Mik Tystone.\"",
        "onEnter": [
          { "action": "set_flag", "key": "owlbear_resolved", "value": true },
          { "action": "set_flag", "key": "owlbear_friendly", "value": true },
          { "action": "add_item", "itemId": "macguffin_collar", "qty": 1 },
          { "action": "add_item", "itemId": "owlbear_hide_vest", "qty": 1 }
        ],
        "choices": [
          { "id": "c_leave_suite", "label": "[Head to Drowtown]", "mechanic": { "type": "navigate", "nextNodeId": "n_street_entry" } }
        ]
      },
      "n_owlbear_victory": {
        "id": "n_owlbear_victory",
        "type": "narrative",
        "text": "The beast drops. You recover its collar and tough hide armor.",
        "onEnter": [
          { "action": "set_flag", "key": "owlbear_resolved", "value": true },
          { "action": "add_item", "itemId": "macguffin_collar", "qty": 1 },
          { "action": "add_item", "itemId": "owlbear_hide_vest", "qty": 1 }
        ],
        "choices": [
          { "id": "c_to_street", "label": "[Leave the suite]", "mechanic": { "type": "navigate", "nextNodeId": "n_street_entry" } }
        ]
      },
      "n_street_entry": {
        "id": "n_street_entry",
        "type": "narrative",
        "text": "Sigil's Drowtown is awake: flashing glyph signs, knife-sellers, and too many witnesses.",
        "choices": [
          { "id": "c_street_observe", "label": "[Scan the crowd (Perception DC 12)]", "mechanic": { "type": "skill_check", "dice": "1d20", "dc": 12, "attribute": "intelligence", "skillId": "perception", "onSuccess": { "nextNodeId": "n_street_observe_success" }, "onFailure": { "nextNodeId": "n_street_observe_fail" } } },
          { "id": "c_to_gate", "label": "[Approach Mik's gate]", "mechanic": { "type": "navigate", "nextNodeId": "n_drowtown_gate" } },
          { "id": "c_clinic", "label": "[Pay for field treatment]", "visibilityRequirements": [{ "type": "not_has_flag", "key": "clinic_used" }, { "type": "stat_check", "stat": "currency", "operator": ">=", "value": 10 }], "mechanic": { "type": "navigate", "nextNodeId": "n_street_clinic" } }
        ]
      },
      "n_street_observe_success": {
        "id": "n_street_observe_success",
        "type": "narrative",
        "text": "You spot a side wall climb route and overhear that the gate captain hates bad liars.",
        "onEnter": [
          { "action": "set_flag", "key": "know_side_route", "value": true }
        ],
        "choices": [
          { "id": "c_to_gate_after_observe", "label": "[Go to the gate]", "mechanic": { "type": "navigate", "nextNodeId": "n_drowtown_gate" } }
        ]
      },
      "n_street_observe_fail": {
        "id": "n_street_observe_fail",
        "type": "narrative",
        "text": "You get distracted by a cart explosion and lose time.",
        "onEnter": [
          { "action": "adjust_hp", "amount": -1 }
        ],
        "choices": [
          { "id": "c_to_gate_after_fail", "label": "[Go to the gate]", "mechanic": { "type": "navigate", "nextNodeId": "n_drowtown_gate" } }
        ]
      },
      "n_street_clinic": {
        "id": "n_street_clinic",
        "type": "narrative",
        "text": "A street cleric patches you up and mutters that Mik's mansion is already on edge.",
        "onEnter": [
          { "action": "set_flag", "key": "clinic_used", "value": true },
          { "action": "adjust_currency", "amount": -10 },
          { "action": "heal", "amount": "1d8+2" }
        ],
        "choices": [
          { "id": "c_to_gate_from_clinic", "label": "[Head to the gate]", "mechanic": { "type": "navigate", "nextNodeId": "n_drowtown_gate" } }
        ]
      },
      "n_drowtown_gate": {
        "id": "n_drowtown_gate",
        "type": "narrative",
        "text": "A bouncer folds his arms. \"Password, paperwork, or pain.\"",
        "choices": [
          { "id": "c_show_receipt", "label": "[Show receipt: OBLIVION]", "visibilityRequirements": [{ "type": "has_item", "itemId": "receipt_oblivion" }], "mechanic": { "type": "navigate", "nextNodeId": "n_gate_pass" } },
          { "id": "c_show_token", "label": "[Flash brass token]", "visibilityRequirements": [{ "type": "has_item", "itemId": "club_token" }], "mechanic": { "type": "navigate", "nextNodeId": "n_gate_pass" } },
          { "id": "c_talk_in", "label": "\"We're expected. Open the gate.\"", "mechanic": { "type": "skill_check", "dice": "1d20", "dc": 13, "attribute": "intelligence", "skillId": "persuasion", "onSuccess": { "nextNodeId": "n_gate_pass" }, "onFailure": { "nextNodeId": "n_gate_refused" } } }
        ]
      },
      "n_gate_refused": {
        "id": "n_gate_refused",
        "type": "narrative",
        "text": "\"No.\" The captain points to a coin tray and taps twice.",
        "choices": [
          { "id": "c_bribe_exact", "label": "[Pay exactly 20g fee]", "visibilityRequirements": [{ "type": "stat_check", "stat": "currency", "operator": "==", "value": 20 }], "mechanic": { "type": "navigate", "nextNodeId": "n_gate_fee_exact" } },
          { "id": "c_bribe_high", "label": "[Pay 25g bribe]", "visibilityRequirements": [{ "type": "stat_check", "stat": "currency", "operator": ">=", "value": 25 }], "mechanic": { "type": "navigate", "nextNodeId": "n_gate_bribe" } },
          { "id": "c_force_gate", "label": "[Force entry]", "mechanic": { "type": "combat_init", "encounterId": "enc_gate_thugs" } }
        ]
      },
      "n_gate_fee_exact": {
        "id": "n_gate_fee_exact",
        "type": "narrative",
        "text": "Exact payment. The captain grunts approval and waves you through.",
        "onEnter": [
          { "action": "adjust_currency", "amount": -20 },
          { "action": "set_flag", "key": "paid_exact_gate_fee", "value": true }
        ],
        "choices": [
          { "id": "c_to_mansion_1", "label": "[Enter courtyard]", "mechanic": { "type": "navigate", "nextNodeId": "n_gate_pass" } }
        ]
      },
      "n_gate_bribe": {
        "id": "n_gate_bribe",
        "type": "narrative",
        "text": "The captain palms the money and pretends not to know you.",
        "onEnter": [
          { "action": "adjust_currency", "amount": -25 },
          { "action": "set_flag", "key": "bribed_gate", "value": true }
        ],
        "choices": [
          { "id": "c_to_mansion_2", "label": "[Enter courtyard]", "mechanic": { "type": "navigate", "nextNodeId": "n_gate_pass" } }
        ]
      },
      "n_gate_thugs_victory": {
        "id": "n_gate_thugs_victory",
        "type": "narrative",
        "text": "The thugs collapse. You strip ringmail from one and pocket a mansion pass.",
        "onEnter": [
          { "action": "add_item", "itemId": "ringmail_reinforced", "qty": 1 },
          { "action": "add_item", "itemId": "mansion_invite", "qty": 1 }
        ],
        "choices": [
          { "id": "c_to_mansion_3", "label": "[Push onward]", "mechanic": { "type": "navigate", "nextNodeId": "n_gate_pass" } }
        ]
      },
      "n_gate_pass": {
        "id": "n_gate_pass",
        "type": "narrative",
        "text": "In the courtyard, you can climb to a side balcony, sneak through staff halls, or confront Mik directly.",
        "choices": [
          { "id": "c_chandelier_run", "label": "[Vault broken fountain (Acrobatics DC 14)]", "mechanic": { "type": "skill_check", "dice": "1d20", "dc": 14, "attribute": "dexterity", "skillId": "acrobatics", "onSuccess": { "nextNodeId": "n_balcony_route" }, "onFailure": { "nextNodeId": "n_balcony_fail" } } },
          { "id": "c_stealth_route", "label": "[Stealth through side hall (DC 13)]", "mechanic": { "type": "skill_check", "dice": "1d20", "dc": 13, "attribute": "dexterity", "skillId": "stealth", "onSuccess": { "nextNodeId": "n_private_wing" }, "onFailure": { "nextNodeId": "n_private_wing_alert" } } },
          { "id": "c_front_door", "label": "[Enter by front door]", "mechanic": { "type": "navigate", "nextNodeId": "n_mik_dialogue" } }
        ]
      },
      "n_balcony_route": {
        "id": "n_balcony_route",
        "type": "narrative",
        "text": "You land cleanly on a balcony. Inside, you find private letters and a locked bassinet room.",
        "onEnter": [
          { "action": "set_flag", "key": "saw_balcony_route", "value": true },
          { "action": "add_item", "itemId": "mik_ledger", "qty": 1 }
        ],
        "choices": [
          { "id": "c_to_mik_from_balcony", "label": "[Confront Mik]", "mechanic": { "type": "navigate", "nextNodeId": "n_mik_dialogue" } }
        ]
      },
      "n_balcony_fail": {
        "id": "n_balcony_fail",
        "type": "narrative",
        "text": "You clip the railing, fall hard, and draw every guard eye.",
        "onEnter": [
          { "action": "adjust_hp", "amount": -6 }
        ],
        "choices": [
          { "id": "c_to_mik_after_fall", "label": "[Stumble into atrium]", "mechanic": { "type": "navigate", "nextNodeId": "n_mik_dialogue" } }
        ]
      },
      "n_private_wing": {
        "id": "n_private_wing",
        "type": "narrative",
        "text": "You slip through private halls, finding medical supplies and proof of Mik's debts.",
        "onEnter": [
          { "action": "set_flag", "key": "found_ledger", "value": true },
          { "action": "add_item", "itemId": "mik_ledger", "qty": 1 },
          { "action": "add_item", "itemId": "adrenaline_shot", "qty": 1 }
        ],
        "choices": [
          { "id": "c_to_mik_after_stealth", "label": "[Confront Mik]", "mechanic": { "type": "navigate", "nextNodeId": "n_mik_dialogue" } }
        ]
      },
      "n_private_wing_alert": {
        "id": "n_private_wing_alert",
        "type": "narrative",
        "text": "A tray crashes. Guards rush you and a crossbow bolt grazes your shoulder.",
        "onEnter": [
          { "action": "adjust_hp", "amount": -4 }
        ],
        "choices": [
          { "id": "c_to_mik_after_alert", "label": "[Push to atrium]", "mechanic": { "type": "navigate", "nextNodeId": "n_mik_dialogue" } }
        ]
      },
      "n_mik_dialogue": {
        "id": "n_mik_dialogue",
        "type": "narrative",
        "text": "Mik Tystone waits at the atrium fountain. \"You and I are ending this now.\"",
        "choices": [
          { "id": "c_read_mik", "label": "\"He's bluffing... I can use that.\"", "mechanic": { "type": "skill_check", "dice": "1d20", "dc": 12, "attribute": "intelligence", "skillId": "insight", "onSuccess": { "nextNodeId": "n_mik_leverage" }, "onFailure": { "nextNodeId": "n_mik_leverage" } } },
          { "id": "c_return_baby", "label": "\"Take the child. Let's end this.\"", "visibilityRequirements": [{ "type": "has_item", "itemId": "drow_baby" }], "mechanic": { "type": "navigate", "nextNodeId": "n_return_baby" } },
          { "id": "c_start_boss", "label": "[Fight Mik]", "mechanic": { "type": "combat_init", "encounterId": "enc_mik_boss" } }
        ]
      },
      "n_mik_leverage": {
        "id": "n_mik_leverage",
        "type": "narrative",
        "text": "You can push leverage from evidence, threaten force, or fold under pressure.",
        "choices": [
          { "id": "c_negotiate_ledger", "label": "\"We both know what this ledger would do to you.\"", "visibilityRequirements": [{ "type": "has_item", "itemId": "mik_ledger" }], "mechanic": { "type": "skill_check", "dice": "1d20", "dc": 15, "attribute": "intelligence", "skillId": "persuasion", "onSuccess": { "nextNodeId": "n_victory_peace" }, "onFailure": { "nextNodeId": "n_talk_failed" } } },
          { "id": "c_bully_mik", "label": "\"Last warning, Mik. Stand down.\"", "mechanic": { "type": "skill_check", "dice": "1d20", "dc": 14, "attribute": "strength", "skillId": "athletics", "onSuccess": { "nextNodeId": "n_victory_truce" }, "onFailure": { "nextNodeId": "n_talk_failed" } } },
          { "id": "c_yield_low_hp", "label": "\"Not today. I'm done fighting.\"", "visibilityRequirements": [{ "type": "stat_check", "stat": "hpCurrent", "operator": "<", "value": 12 }], "mechanic": { "type": "navigate", "nextNodeId": "n_victory_truce" } }
        ]
      },
      "n_return_baby": {
        "id": "n_return_baby",
        "type": "narrative",
        "text": "Mik takes the baby quietly. \"This changes things. Maybe.\"",
        "onEnter": [
          { "action": "remove_item", "itemId": "drow_baby", "qty": 1 },
          { "action": "set_flag", "key": "returned_baby", "value": true }
        ],
        "choices": [
          { "id": "c_close_talk", "label": "\"No more blood. We walk away now.\"", "mechanic": { "type": "skill_check", "dice": "1d20", "dc": 12, "attribute": "intelligence", "skillId": "persuasion", "onSuccess": { "nextNodeId": "n_victory_peace" }, "onFailure": { "nextNodeId": "n_victory_truce" } } },
          { "id": "c_betrayal_fight", "label": "[Break truce, draw steel]", "mechanic": { "type": "combat_init", "encounterId": "enc_mik_boss" } }
        ]
      },
      "n_talk_failed": {
        "id": "n_talk_failed",
        "type": "narrative",
        "text": "Words fail. Mik snaps his fingers and the atrium becomes an arena.",
        "choices": [
          { "id": "c_to_boss", "label": "[Fight]", "mechanic": { "type": "combat_init", "encounterId": "enc_mik_boss" } }
        ]
      },
      "n_mik_victory": {
        "id": "n_mik_victory",
        "type": "ending",
        "text": "Mik drops. You leave with bruises, reputation, and coin enough to regret this again tomorrow.",
        "onEnter": [
          { "action": "adjust_currency", "amount": 90 }
        ],
        "choices": [
          { "id": "c_restart_boss_win", "label": "[Play again]", "mechanic": { "type": "navigate", "nextNodeId": "n_start" } }
        ]
      },
      "n_victory_peace": {
        "id": "n_victory_peace",
        "type": "ending",
        "text": "You broker peace with leverage and nerve. No one dies, everyone lies, and you get paid to disappear.",
        "onEnter": [
          { "action": "adjust_currency", "amount": 120 }
        ],
        "choices": [
          { "id": "c_restart_peace", "label": "[Play again]", "mechanic": { "type": "navigate", "nextNodeId": "n_start" } }
        ]
      },
      "n_victory_truce": {
        "id": "n_victory_truce",
        "type": "ending",
        "text": "You survive by compromise. It is not glorious, but it is alive.",
        "choices": [
          { "id": "c_restart_truce", "label": "[Play again]", "mechanic": { "type": "navigate", "nextNodeId": "n_start" } }
        ]
      },
      "n_game_over": {
        "id": "n_game_over",
        "type": "ending",
        "text": "The hangover takes another hero.",
        "choices": [
          { "id": "c_restart_loss", "label": "[Try again]", "mechanic": { "type": "navigate", "nextNodeId": "n_start" } }
        ]
      }
    },
    "items": {
